<?xml version="1.0"?>
<!--
  full_match.xml — 全场完整行为树

  适用场景: 完整比赛流程 (准备区 → 美林赛段 → 决赛区)
  数据驱动: 通过 /planning/segments topic 接收 JSON segment plan,
           PopNextSegment 弹出每个 segment 并写入 blackboard,
           子节点从 blackboard 读取参数执行。

  支持的 segment_type: SPEAR_PREP, SPEAR_GRASP, ALIGN, DOCK,
                       MOVE2, GRASP, CLIMB, STORE1, STORE2, EXIT,
                       FINAL_MOVE2, PLACE_MID, PLACE_HIGH, FINISH

  Groot2 监控: 默认端口 1667, 可直接连接查看实时树状态

  启动示例:
    ros2 launch r2_bt bt_engine.launch.py tree_file:=full_match.xml
-->
<root BTCPP_format="4" main_tree_to_execute="FullMatch">
  <BehaviorTree ID="FullMatch">
    <Sequence>
      <PopNextSegment queue="{segment_queue}"
                      current_segment_index="{current_segment_index}"
                      segment_type="{segment_type}"
                      segment_debug_name="{segment_debug_name}"
                      target_x="{target_x}"
                      target_y="{target_y}"
                      target_yaw="{target_yaw}"
                      max_speed="{max_speed}"
                      timeout_sec="{timeout_sec}"
                      climb_mode="{climb_mode}"
                      climb_direction="{climb_direction}"
                      climb_height="{climb_height}"
                      arm_command="{arm_command}"
                      wait_result="{wait_result}"
                      spear_command="{spear_command}"/>

      <Fallback>
        <SubTree ID="PrepareArea" _autoremap="true"/>
        <SubTree ID="MeilinArea" _autoremap="true"/>
        <SubTree ID="FinalArea" _autoremap="true"/>

        <SetDebugStatus execution_state="ACTION_FAILED"
                        active_action="SegmentDispatch"
                        last_error="Unsupported segment_type"/>
      </Fallback>
    </Sequence>
  </BehaviorTree>

  <BehaviorTree ID="PrepareArea">
    <Fallback>
      <Sequence>
        <IsSegmentType expected="SPEAR_PREP" actual="{segment_type}"/>
        <RetrySegment num_attempts="3">
          <Sequence>
            <SpearAction command="{spear_command}"
                         timeout_sec="{timeout_sec}"
                         message="{last_error}"/>
            <MoveToPose target_x="{target_x}"
                        target_y="{target_y}"
                        target_yaw="{target_yaw}"
                        max_speed="{max_speed}"
                        timeout_sec="{timeout_sec}"
                        error_msg="{last_error}"/>
          </Sequence>
        </RetrySegment>
      </Sequence>

      <Sequence>
        <IsSegmentType expected="SPEAR_GRASP" actual="{segment_type}"/>
        <RetrySegment num_attempts="3">
          <SpearAction command="{spear_command}"
                       timeout_sec="{timeout_sec}"
                       message="{last_error}"/>
        </RetrySegment>
      </Sequence>

      <Sequence>
        <IsSegmentType expected="ALIGN" actual="{segment_type}"/>
        <RetrySegment num_attempts="3">
          <MoveToPose target_x="{target_x}"
                      target_y="{target_y}"
                      target_yaw="{target_yaw}"
                      max_speed="{max_speed}"
                      timeout_sec="{timeout_sec}"
                      error_msg="{last_error}"/>
        </RetrySegment>
      </Sequence>

      <Sequence>
        <IsSegmentType expected="DOCK" actual="{segment_type}"/>
        <RetrySegment num_attempts="3">
          <Sequence>
            <SpearAction command="dock_extend"
                         timeout_sec="{timeout_sec}"
                         message="{last_error}"/>
            <WaitForR1Signal signal_topic="/r1_ready"
                             timeout_sec="60.0"/>
            <SpearAction command="dock_release"
                         timeout_sec="{timeout_sec}"
                         message="{last_error}"/>
          </Sequence>
        </RetrySegment>
      </Sequence>
    </Fallback>
  </BehaviorTree>

  <BehaviorTree ID="MeilinArea">
    <Fallback>
      <Sequence>
        <IsSegmentType expected="MOVE2" actual="{segment_type}"/>
        <RetrySegment num_attempts="3">
          <MoveToPose target_x="{target_x}"
                      target_y="{target_y}"
                      target_yaw="{target_yaw}"
                      max_speed="{max_speed}"
                      timeout_sec="{timeout_sec}"
                      error_msg="{last_error}"/>
        </RetrySegment>
      </Sequence>

      <Sequence>
        <IsSegmentType expected="GRASP" actual="{segment_type}"/>
        <RetrySegment num_attempts="3">
          <Sequence>
            <SuspensionControl mode="{grasp_suspension_mode}"
                               direction="0"
                               height="{height_diff}"
                               timeout_sec="10.0"
                               message="{last_error}"/>
            <ArmAction command="{arm_command}"
                       wait_result="true"
                       timeout_sec="{timeout_sec}"
                       message="{last_error}"/>
          </Sequence>
        </RetrySegment>
      </Sequence>

      <Sequence>
        <IsSegmentType expected="CLIMB" actual="{segment_type}"/>
        <IsStringNonEmpty value="{arm_command}"/>
        <Fallback>
          <RetrySegment num_attempts="3">
            <Parallel success_count="3" failure_count="1">
              <SuspensionControl mode="{climb_mode}"
                                 direction="{climb_direction}"
                                 height="{climb_height}"
                                 timeout_sec="{timeout_sec}"
                                 message="{last_error}"/>
              <MoveToPose target_x="{target_x}"
                          target_y="{target_y}"
                          target_yaw="{target_yaw}"
                          max_speed="{max_speed}"
                          timeout_sec="{timeout_sec}"
                          error_msg="{last_error}"/>
              <ArmAction command="{arm_command}"
                         wait_result="{wait_result}"
                         timeout_sec="{timeout_sec}"
                         message="{last_error}"/>
            </Parallel>
          </RetrySegment>
          <ForceFailure>
            <SuspensionControl mode="3"
                               direction="0"
                               height="30.0"
                               timeout_sec="10.0"
                               message="{last_error}"/>
          </ForceFailure>
        </Fallback>
      </Sequence>

      <Sequence>
        <IsSegmentType expected="CLIMB" actual="{segment_type}"/>
        <IsStringEmpty value="{arm_command}"/>
        <Fallback>
          <RetrySegment num_attempts="3">
            <Parallel success_count="2" failure_count="1">
              <SuspensionControl mode="{climb_mode}"
                                 direction="{climb_direction}"
                                 height="{climb_height}"
                                 timeout_sec="{timeout_sec}"
                                 message="{last_error}"/>
              <MoveToPose target_x="{target_x}"
                          target_y="{target_y}"
                          target_yaw="{target_yaw}"
                          max_speed="{max_speed}"
                          timeout_sec="{timeout_sec}"
                          error_msg="{last_error}"/>
            </Parallel>
          </RetrySegment>
          <ForceFailure>
            <SuspensionControl mode="3"
                               direction="0"
                               height="30.0"
                               timeout_sec="10.0"
                               message="{last_error}"/>
          </ForceFailure>
        </Fallback>
      </Sequence>

      <Sequence>
        <IsSegmentType expected="STORE1" actual="{segment_type}"/>
        <RetrySegment num_attempts="3">
          <ArmAction command="{arm_command}"
                     wait_result="{wait_result}"
                     timeout_sec="{timeout_sec}"
                     message="{last_error}"/>
        </RetrySegment>
      </Sequence>

      <Sequence>
        <IsSegmentType expected="STORE2" actual="{segment_type}"/>
        <RetrySegment num_attempts="3">
          <ArmAction command="{arm_command}"
                     wait_result="{wait_result}"
                     timeout_sec="{timeout_sec}"
                     message="{last_error}"/>
        </RetrySegment>
      </Sequence>

      <Sequence>
        <IsSegmentType expected="EXIT" actual="{segment_type}"/>
        <RetrySegment num_attempts="3">
          <Sequence>
            <ArmAction command="{arm_command}"
                       wait_result="true"
                       timeout_sec="{timeout_sec}"
                       message="{last_error}"/>
            <SuspensionControl mode="3"
                               direction="0"
                               height="0.0"
                               timeout_sec="10.0"
                               message="{last_error}"/>
            <MoveToPose target_x="{target_x}"
                        target_y="{target_y}"
                        target_yaw="{target_yaw}"
                        max_speed="{max_speed}"
                        timeout_sec="{timeout_sec}"
                        error_msg="{last_error}"/>
          </Sequence>
        </RetrySegment>
      </Sequence>
    </Fallback>
  </BehaviorTree>

  <BehaviorTree ID="FinalArea">
    <Fallback>
      <Sequence>
        <IsSegmentType expected="FINAL_MOVE2" actual="{segment_type}"/>
        <RetrySegment num_attempts="3">
          <MoveToPose target_x="{target_x}"
                      target_y="{target_y}"
                      target_yaw="{target_yaw}"
                      max_speed="{max_speed}"
                      timeout_sec="{timeout_sec}"
                      error_msg="{last_error}"/>
        </RetrySegment>
      </Sequence>

      <Sequence>
        <IsSegmentType expected="PLACE_MID" actual="{segment_type}"/>
        <RetrySegment num_attempts="3">
          <Sequence>
            <WaitArmIdle timeout_sec="{timeout_sec}" message="{last_error}"/>
            <ArmAction command="{arm_command}"
                       wait_result="true"
                       timeout_sec="{timeout_sec}"
                       message="{last_error}"/>
          </Sequence>
        </RetrySegment>
      </Sequence>

      <Sequence>
        <IsSegmentType expected="PLACE_HIGH" actual="{segment_type}"/>
        <RetrySegment num_attempts="3">
          <Sequence>
            <WaitArmIdle timeout_sec="{timeout_sec}" message="{last_error}"/>
            <ArmAction command="{arm_command}"
                       wait_result="true"
                       timeout_sec="{timeout_sec}"
                       message="{last_error}"/>
          </Sequence>
        </RetrySegment>
      </Sequence>

      <Sequence>
        <IsSegmentType expected="FINISH" actual="{segment_type}"/>
        <RetrySegment num_attempts="3">
          <Sequence>
            <WaitArmIdle timeout_sec="{timeout_sec}" message="{last_error}"/>
            <ArmAction command="{arm_command}"
                       wait_result="true"
                       timeout_sec="{timeout_sec}"
                       message="{last_error}"/>
            <SuspensionControl mode="3"
                               direction="0"
                               height="0.0"
                               timeout_sec="10.0"
                               message="{last_error}"/>
          </Sequence>
        </RetrySegment>
      </Sequence>
    </Fallback>
  </BehaviorTree>
</root>
