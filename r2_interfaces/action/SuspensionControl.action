# SuspensionControl.action — 主动悬挂上下台阶动作
# 由 BT 决策层调用，由 r2_hardware Action Server 执行。
# 设计约定:
# - direction 表示机器人相对台阶的运动方向。
# - mode 表示本次动作语义；AUTO 由执行层根据传感器判断上/下台阶。
# - height 为已知台阶高度时可传 +-200 或 +-400。
#   执行层会映射为悬挂准备高度: 200 -> 205mm, 400 -> 410mm。
#   下台阶/动作结束后恢复到 20mm 行驶高度。

uint8 MODE_AUTO=0
uint8 MODE_CLIMB_UP=1
uint8 MODE_CLIMB_DOWN=2
uint8 MODE_DIRECT=3  # 直接设置四轮统一高度（height 参数为目标高度 mm）

uint8 DIR_FORWARD=0
uint8 DIR_LEFT=1
uint8 DIR_RIGHT=2
uint8 DIR_BACKWARD=3

uint8 mode
uint8 direction
float32 height
float32 timeout_sec
---
bool success
string message
int32 final_state
float32 elapsed_sec
---
int32 current_state  # 当前状态机状态码
float32 elapsed_sec
float32[] distance_data  # 测距数据
float32[] photoelectric_data  # 光电数据
float32[] wheel_heights_current
float32[] wheel_heights_target
